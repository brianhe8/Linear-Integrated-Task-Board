{
  "name": "taskboardwlinear",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app/backend",
    "app/frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=app/backend & npm run dev --workspace=app/frontend",
    "dev:backend": "npm run dev --workspace=app/backend",
    "dev:frontend": "npm run dev --workspace=app/frontend",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspace=app/backend",
    "test:run": "npm run test:run --workspace=app/backend",
    "type-check": "npm run type-check --workspace=app/backend",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
